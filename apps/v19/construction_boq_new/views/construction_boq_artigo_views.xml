<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="view_construction_boq_artigo_list" model="ir.ui.view">
    <field name="name">construction.boq.artigo.list</field>
    <field name="model">construction.boq.artigo</field>
    <field name="arch" type="xml">
        <list string="BOQ Articles">
            <field name="code"/>
            <field name="name"/>
            <field name="boq_id" string="BOQ"/>
            <field name="section_id" optional="show" string="Section"/>
            <field name="product_id" optional="show"/>
            <field name="product_categ_id" optional="show" string="Category"/>
            <field name="uom_id" string="Unit"/>
            <field name="qty_contract" string="Qty"/>
            <field name="price_unit" string="Unit Price"/>
            <field name="total_contract" widget="monetary" string="Total"/>
            <field name="show_in_stock" optional="show"/>
            <field name="obs" optional="show" string="Notes"/>
        </list>
    </field>
</record>

<record id="view_construction_boq_artigo_form" model="ir.ui.view">
    <field name="name">construction.boq.artigo.form</field>
    <field name="model">construction.boq.artigo</field>
    <field name="arch" type="xml">
        <form string="BOQ Article">
            <sheet>
                <group>
                    <group string="Structure">
                        <field name="boq_id" readonly="1"/>
                        <field name="section_id"
                               domain="[('boq_id','=',boq_id),('is_leaf','=',True)]"/>
                        <field name="code"/>
                        <field name="sequence"/>
                    </group>
                    <group string="Odoo Product">
                        <field name="product_id"/>
                        <field name="product_categ_id" readonly="1"/>
                        <field name="uom_id"/>
                    </group>
                </group>
                <group>
                    <field name="name" string="Description"/>
                </group>
                <group>
                    <group string="Quantities and Pricing">
                        <field name="qty_contract"/>
                        <field name="price_unit"/>
                        <field name="total_contract" widget="monetary" readonly="1"/>
                    </group>
                    <group string="Stock">
                        <field name="show_in_stock"/>
                        <field name="qty_on_hand" readonly="1"
                               invisible="not product_id"/>
                    </group>
                </group>
                <group string="Notes">
                    <field name="obs" nolabel="1"/>
                </group>
            </sheet>
        </form>
    </field>
</record>

<record id="action_construction_boq_artigo" model="ir.actions.act_window">
    <field name="name">BOQ Articles</field>
    <field name="res_model">construction.boq.artigo</field>
    <field name="view_mode">list,form</field>
</record>

</odoo>
