<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Overview dashboard action — landing page when clicking
        "Construction BOQ" in the Odoo home screen.
        Uses the Projects list as the entry point.
    -->
    <record id="action_construction_overview" model="ir.actions.act_window">
        <field name="name">Construction BOQ</field>
        <field name="res_model">construction.obra</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_in_progress': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Welcome to Construction BOQ Manager
            </p>
            <p>
                Start by creating your first Construction Project,
                then add a Bill of Quantities.
            </p>
        </field>
    </record>

</odoo>
