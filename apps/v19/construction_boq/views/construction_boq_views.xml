<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="view_construction_boq_list" model="ir.ui.view">
    <field name="name">construction.boq.list</field>
    <field name="model">construction.boq</field>
    <field name="arch" type="xml">
        <list string="Bills of Quantities"
              decoration-muted="state == 'archived'"
              decoration-success="state == 'shared'"
              decoration-warning="state == 'draft'">
            <field name="revision_label" string="Rev."/>
            <field name="name"/>
            <field name="obra_id" string="Project"/>
            <field name="state" widget="badge"
                   decoration-success="state == 'shared'"
                   decoration-warning="state == 'draft'"
                   decoration-muted="state == 'archived'"/>
            <field name="is_active_revision" string="Active"/>
            <field name="capitulo_count" string="Chapters"/>
            <field name="artigo_count" string="Articles"/>
            <field name="total_boq" widget="monetary" string="Total"/>
            <field name="user_id" optional="show"/>
            <field name="date_created" optional="show"/>
            <field name="date_shared" optional="show"/>
            <button name="action_open_editor" type="object"
                    string="Open Editor" class="btn-primary" icon="fa-table"/>
        </list>
    </field>
</record>

<record id="view_construction_boq_form" model="ir.ui.view">
    <field name="name">construction.boq.form</field>
    <field name="model">construction.boq</field>
    <field name="arch" type="xml">
        <form string="Bill of Quantities">
            <header>
                <button name="action_share" type="object"
                        string="Share (lock)"
                        class="btn-primary"
                        invisible="state != 'draft'"
                        confirm="Sharing will lock this BOQ for editing. Continue?"/>
                <button name="action_new_revision" type="object"
                        string="New Revision"
                        invisible="state != 'shared'"/>
                <button name="action_archive_boq" type="object"
                        string="Archive"
                        invisible="state == 'archived'"/>
                <button name="action_reset_to_draft" type="object"
                        string="Reset to Draft"
                        invisible="state != 'archived'"/>
                <button name="action_open_editor" type="object"
                        string="Open BOQ Editor"
                        class="btn-primary" icon="fa-table"/>
                <field name="state" widget="statusbar"
                       statusbar_visible="draft,shared,archived"/>
            </header>
            <sheet>
                <div class="oe_button_box" name="button_box">
                    <button name="action_open_editor" type="object"
                            class="oe_stat_button" icon="fa-table">
                        <field name="artigo_count" widget="statinfo" string="Articles"/>
                    </button>
                    <button class="oe_stat_button" icon="fa-folder-o" type="object">
                        <field name="capitulo_count" widget="statinfo" string="Chapters"/>
                    </button>
                </div>
                <div class="oe_title">
                    <label for="name"/>
                    <h1><field name="name" placeholder="BOQ Name"/></h1>
                    <div>
                        <field name="revision_label" class="oe_inline" readonly="1"/>
                        &#160;
                        <field name="is_active_revision" class="oe_inline"
                               widget="boolean_toggle"/>
                        <label for="is_active_revision" class="oe_inline"> Active Revision</label>
                    </div>
                </div>
                <group>
                    <group>
                        <field name="obra_id" string="Project"/>
                        <field name="version" readonly="1"/>
                        <field name="parent_revision_id" readonly="1"
                               invisible="not parent_revision_id"/>
                    </group>
                    <group>
                        <field name="total_boq" widget="monetary"/>
                        <field name="user_id"/>
                        <field name="date_created" readonly="1"/>
                        <field name="date_shared" readonly="1"
                               invisible="not date_shared"/>
                        <field name="shared_by_id" readonly="1"
                               invisible="not shared_by_id"/>
                    </group>
                </group>
                <group string="Notes">
                    <field name="notes" nolabel="1"
                           placeholder="Exclusions, conditions, general notes..."/>
                </group>
                <notebook>
                    <page string="Revision History"
                          invisible="not child_revision_ids">
                        <field name="child_revision_ids" readonly="1">
                            <list>
                                <field name="revision_label"/>
                                <field name="name"/>
                                <field name="state" widget="badge"/>
                                <field name="total_boq" widget="monetary"/>
                                <field name="user_id"/>
                                <field name="date_created"/>
                            </list>
                        </field>
                    </page>
                </notebook>
            </sheet>
            <chatter/>
        </form>
    </field>
</record>

<record id="view_construction_boq_search" model="ir.ui.view">
    <field name="name">construction.boq.search</field>
    <field name="model">construction.boq</field>
    <field name="arch" type="xml">
        <search>
            <field name="name"/>
            <field name="obra_id" string="Project"/>
            <field name="revision_label"/>
            <filter name="draft" string="Draft"
                    domain="[('state','=','draft')]"/>
            <filter name="shared" string="Shared"
                    domain="[('state','=','shared')]"/>
            <filter name="archived" string="Archived"
                    domain="[('state','=','archived')]"/>
            <filter name="active_rev" string="Active Revision"
                    domain="[('is_active_revision','=',True)]"/>
            <filter name="grp_project" string="Group by Project"
                    context="{'group_by':'obra_id'}"/>
            <filter name="grp_state" string="Group by Status"
                    context="{'group_by':'state'}"/>
        </search>
    </field>
</record>

<record id="action_construction_boq" model="ir.actions.act_window">
    <field name="name">Bills of Quantities</field>
    <field name="res_model">construction.boq</field>
    <field name="view_mode">list,form</field>
    <field name="context">{'search_default_active_rev': 1}</field>
    <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
            Create your first Bill of Quantities
        </p>
    </field>
</record>

</odoo>
