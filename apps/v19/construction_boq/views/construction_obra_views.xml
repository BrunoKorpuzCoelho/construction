<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="view_construction_obra_list" model="ir.ui.view">
    <field name="name">construction.obra.list</field>
    <field name="model">construction.obra</field>
    <field name="arch" type="xml">
        <list string="Construction Projects"
              decoration-info="state == 'in_progress'"
              decoration-success="state == 'completed'"
              decoration-muted="state in ('closed','suspended')">
            <field name="ref_interna" string="Ref."/>
            <field name="name" string="Project Name"/>
            <field name="partner_id" string="Client"/>
            <field name="tipo_obra" string="Type"/>
            <field name="state" widget="badge"
                   decoration-info="state == 'in_progress'"
                   decoration-warning="state in ('proposal','awarded')"
                   decoration-success="state == 'completed'"/>
            <field name="valor_contrato" widget="monetary" string="Contract Value"/>
            <field name="boq_count" string="BOQs"/>
            <field name="user_id" optional="show"/>
            <field name="date_start" optional="show"/>
            <button name="action_open_boq_list" type="object"
                    string="BOQs" icon="fa-list-ol"/>
        </list>
    </field>
</record>

<record id="view_construction_obra_form" model="ir.ui.view">
    <field name="name">construction.obra.form</field>
    <field name="model">construction.obra</field>
    <field name="arch" type="xml">
        <form string="Construction Project">
            <header>
                <field name="state" widget="statusbar"
                       statusbar_visible="prospect,proposal,awarded,in_progress,completed"/>
            </header>
            <sheet>
                <div class="oe_button_box" name="button_box">
                    <button name="action_open_boq_list" type="object"
                            class="oe_stat_button" icon="fa-list-ol">
                        <field name="boq_count" widget="statinfo" string="BOQs"/>
                    </button>
                </div>
                <div class="oe_title">
                    <label for="name"/>
                    <h1><field name="name" placeholder="Project Name"/></h1>
                    <div>
                        <field name="ref_interna" class="oe_inline" readonly="1"/>
                        &#160;&#183;&#160;
                        <field name="tipo_empreitada" class="oe_inline"/>
                    </div>
                </div>
                <group>
                    <group string="Identification">
                        <field name="partner_id"/>
                        <field name="partner_fiscalizacao_id"/>
                        <field name="user_id"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                        <field name="ref_concurso"
                               invisible="tipo_empreitada not in ['public_tender','public_works']"/>
                        <field name="tipo_obra"/>
                    </group>
                    <group string="Dates and Financials">
                        <field name="date_awarded"/>
                        <field name="date_start"/>
                        <field name="date_end_contract"/>
                        <field name="date_end_forecast"/>
                        <field name="valor_contrato" widget="monetary"/>
                        <field name="retencao_pct"/>
                        <field name="analytic_account_id"/>
                    </group>
                </group>
                <group string="Location">
                    <field name="street"/>
                    <field name="city"/>
                    <field name="zip"/>
                    <field name="country_id"/>
                </group>
                <group string="Autodesk ACC"
                       invisible="not acc_project_id and not acc_project_url">
                    <field name="acc_project_id"/>
                    <field name="acc_project_url" widget="url"/>
                </group>
                <group string="Active BOQ">
                    <field name="boq_active_id" readonly="1"/>
                </group>
            </sheet>
            <chatter/>
        </form>
    </field>
</record>

<record id="view_construction_obra_search" model="ir.ui.view">
    <field name="name">construction.obra.search</field>
    <field name="model">construction.obra</field>
    <field name="arch" type="xml">
        <search>
            <field name="name" string="Project"/>
            <field name="ref_interna"/>
            <field name="ref_concurso"/>
            <field name="partner_id"/>
            <field name="user_id"/>
            <filter name="in_progress" string="In Progress"
                    domain="[('state','=','in_progress')]"/>
            <filter name="awarded" string="Awarded"
                    domain="[('state','=','awarded')]"/>
            <filter name="proposal" string="Proposals"
                    domain="[('state','=','proposal')]"/>
            <filter name="completed" string="Completed"
                    domain="[('state','=','completed')]"/>
            <filter name="public" string="Public Tenders"
                    domain="[('tipo_empreitada','in',['public_tender','public_works'])]"/>
            <filter name="grp_type" string="Group by Type"
                    context="{'group_by':'tipo_obra'}"/>
            <filter name="grp_state" string="Group by Status"
                    context="{'group_by':'state'}"/>
            <filter name="grp_manager" string="Group by Manager"
                    context="{'group_by':'user_id'}"/>
        </search>
    </field>
</record>

<record id="action_construction_obra" model="ir.actions.act_window">
    <field name="name">Construction Projects</field>
    <field name="res_model">construction.obra</field>
    <field name="view_mode">list,form</field>
    <field name="context">{'search_default_in_progress': 1}</field>
    <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
            Create your first Construction Project
        </p>
    </field>
</record>

</odoo>
